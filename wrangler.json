{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "geopiratesstreamhomepage",
  "compatibility_date": "2026-06-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "geopirates.stream", "custom_domain": true },
    { "pattern": "www.geopirates.stream", "custom_domain": true }
  ]
}